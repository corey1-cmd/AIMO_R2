# ═══════════════════════════════════════════════════════════════
# détente — 환경변수 템플릿
#
# 사용법:
#   1. 이 파일을 .env.local로 복사
#   2. 아래 값을 Supabase 프로젝트 대시보드에서 복사하여 채움
#   3. Vercel 배포 시에는 Project Settings → Environment Variables 에
#      동일한 값을 VITE_ 접두사 유지한 채로 등록
#
# VITE_ 접두사가 없는 변수는 클라이언트 번들에 포함되지 않습니다.
# Supabase anon key는 클라이언트 노출이 전제이므로 VITE_ 접두사가 올바릅니다.
# Service role key는 절대 VITE_ 접두사로 노출하지 않습니다 (detnete는 사용 안 함).
# ═══════════════════════════════════════════════════════════════

# Supabase 프로젝트 URL
# 예: https://abcdefghijklmnop.supabase.co
VITE_SUPABASE_URL=

# Supabase anon (public) key
# Project Settings → API → Project API keys → anon / public 에서 복사
VITE_SUPABASE_ANON_KEY=

# ─── 선택: 로컬 개발 전용 ───────────────────────────────────────

# Google OAuth redirect URL override (로컬 개발용)
# 기본값은 window.location.origin 으로 자동 계산되므로 비워둬도 동작합니다.
# 단, Supabase Dashboard → Authentication → URL Configuration 에
# http://localhost:5173 를 Redirect URL로 추가해야 합니다.
# VITE_AUTH_REDIRECT_URL=http://localhost:5173/auth/callback
